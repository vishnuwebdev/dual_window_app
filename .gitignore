# Local runtime config — admin-editable settings (admin PIN, drop-off PIN,
# SMS template, locker mapping), created with defaults by ConfigService on
# first launch. Mirrors the Android app's on-device `admin.json`.
# config.json

# Local runtime data — parcel drop-off/collection records, created (empty)
# by MockKioskRepository on first launch. Mirrors the Android app's
# on-device `db.json`.
# db.json

# Flutter build directories
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies

# Dart/Flutter IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code cache
.vscode/

# Generated files (build_runner-style codegen, if this project ever adds
# any — NOT the protoc/gRPC output in lib/generated/, which must ship
# with the repo since not every build machine has protoc installed; see
# protos/CODEGEN.md and the negation at the bottom of this file). Prior
# versions of this file ignored *.pb.dart/*.pbgrpc.dart/*.pbjson.dart
# globally, which silently excluded 3 of the 4 files
# locker_grpc_service.dart needs, causing "No such file or directory" on
# any machine that only ever `git pull`s instead of running codegen
# locally (e.g. a Raspberry Pi build).
*.g.dart

# Android Studio
.gradle/
local.properties
*.jks
*.keystore

# iOS/macOS
ios/.generated/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec

# Platform specific gitignores
windows/flutter/generated_plugins.cmake
windows/flutter/generated_package_config.cmake
windows/plugins/*/

# Linux
linux/flutter/generated_plugins.cmake
linux/flutter/generated_package_config.cmake
linux/plugins/*/
build/linux/

# macOS
macos/Flutter/Flutter.framework
macos/Flutter/Flutter.podspec

# Environment variables
.env
.env.local
.env.*.local

# Miscellaneous
*.log
*.pyc
*.class
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# Dependencies
pubspec.lock
packages/

# Test artifacts
coverage/
.nyc_output/

# Keep essential files — the protoc/gRPC client output (see
# protos/CODEGEN.md) ships with the repo rather than being regenerated on
# every machine.
!lib/generated/
!lib/generated/*.dart
